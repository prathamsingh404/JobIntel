# Ingestion Pipeline Environment Configuration
DATABASE_URL=sqlite+aiosqlite:///jobs.db
# For PostgreSQL: postgresql+asyncpg://postgres:postgres@localhost:5432/job_discovery

# AI Provider Configuration
# Supported: gemini, openai, groq, mock
AI_PROVIDER=mock

# API Keys
GEMINI_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# App Server Configuration
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=info
